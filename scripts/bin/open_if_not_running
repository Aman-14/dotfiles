#!/bin/bash

# This script checks if a specified application is running and opens it if it's not.
# It takes one argument: the path to the application.
# Usage: open_if_not_running <app_path>

if [ $# -eq 0 ]; then
	echo "Usage: open_if_not_running <app_path>"
	exit 1
fi

app_path="$1"
app_name=$(basename "$app_path")

if ! pgrep -x "$app_name" >/dev/null; then
	open -a "$app_path"
fi
